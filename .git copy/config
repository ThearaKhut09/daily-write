[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
	url = https://github.com/Foundation-Gen05/daily-write.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "fixprofile"]
	remote = origin
	merge = refs/heads/fixprofile
	vscode-merge-base = origin/main
[branch "dev"]
	remote = origin
	merge = refs/heads/dev
	vscode-merge-base = origin/dev
